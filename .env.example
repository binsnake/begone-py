# Copy to .env and fill in. Never commit the real .env.
DISCORD_TOKEN=your-bot-token-here

# Channel where detections/alerts are posted (numeric channel ID).
ALERT_CHANNEL_ID=000000000000000000

# Optional: path to the tesseract binary if it is not on PATH.
# Leave blank to auto-discover from PATH (works on Linux/macOS/Windows).
#   Windows:  C:\Program Files\Tesseract-OCR\tesseract.exe
#   Linux:    /usr/bin/tesseract        (apt install tesseract-ocr)
#   macOS:    /opt/homebrew/bin/tesseract (brew install tesseract)
TESSERACT_CMD=
